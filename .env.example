# LLM 配置（必填）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat

# 新闻搜索配置（至少配置一个）
SERPAPI_KEY=
TAVILY_KEY=
BRAVE_KEY=
BOCHA_KEY=

# 妙想金融数据源（推荐配置）— 配置后自动成为第一优先级数据源
# 前往获取 API Key: https://dl.dfcfs.com/m/itc4
MX_APIKEY=

# 分析参数（可选）
BIAS_THRESHOLD=5.0
NEWS_MAX_AGE_DAYS=3
ENABLE_CHIP=true

# 日志配置（可选）— DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
